---
import Layout from '../../layouts/Layout.astro';
import NewsDetail from '../../components/NewsDetail';
import { fetchNews } from '../../services/api';

export async function getStaticPaths() {
  // The cryptocurrency.cv API blocks server-side (non-browser) requests.
  // News detail pages hydrate client-side using the zustand cached news store.
  return [];
}

const { id } = Astro.params;
const { initialNews } = Astro.props;
---

<Layout>
  <NewsDetail id={id} initialNews={initialNews} client:load />
</Layout>
